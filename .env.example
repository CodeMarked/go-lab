# MySQL (used by Docker Compose and local tooling)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=toor
DB_NAME=todosdb

API_PORT=5000
GIN_MODE=release

# JWT access tokens (HS256). Use a long random secret in production.
JWT_SECRET=change-me-to-at-least-32-chars-long!!
JWT_ISSUER=go-lab
JWT_AUDIENCE=go-lab-api
JWT_ACCESS_TTL_SECONDS=900

# Backend-only platform credentials for server token issuance (/api/v1/auth/token and /api/v1/auth/bootstrap).
# Rotate in production; never commit real .env.
PLATFORM_CLIENT_ID=dev-platform
PLATFORM_CLIENT_SECRET=change-me-dev-secret-min-length-16

# After `migrate up`, set to latest migration version so /readyz fails if DB is behind.
MIGRATION_EXPECTED_VERSION=2

# Comma-separated browser origins (no wildcard). Empty is not valid — default applied in code if unset.
CORS_ALLOWED_ORIGINS=http://localhost:4200
