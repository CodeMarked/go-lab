# MySQL (used by Docker Compose and local tooling)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=toor
DB_NAME=todosdb

API_PORT=5000
GIN_MODE=release

# JWT access tokens (HS256). Use a long random secret in production.
JWT_SECRET=change-me-to-at-least-32-chars-long!!
# Optional during rotation: previous secret still verifies. See docs/jwt-rotation.md
# JWT_SECRET_PREVIOUS=
JWT_ISSUER=go-lab
JWT_AUDIENCE=go-lab-api
JWT_ACCESS_TTL_SECONDS=900

# Backend-only platform credentials for server token issuance (/api/v1/auth/token and /api/v1/auth/bootstrap).
# Rotate in production; never commit real .env.
PLATFORM_CLIENT_ID=dev-platform
PLATFORM_CLIENT_SECRET=change-me-dev-secret-min-length-16

# After `migrate up`, set to latest migration version so /readyz fails if DB is behind.
MIGRATION_EXPECTED_VERSION=2

# Browser session (POST /api/v1/auth/login). HttpOnly cookie; SPA never sees the token.
# For local HTTP (Compose), Secure must be false; behind HTTPS set true.
SESSION_COOKIE_NAME=gl_session
SESSION_COOKIE_SECURE=false
SESSION_SAMESITE=Lax
SESSION_IDLE_TTL_SECONDS=1800
SESSION_ABSOLUTE_TTL_SECONDS=86400

# CSRF double-submit (non-HttpOnly cookie + matching header on cookie mutating requests). CORS allowlist includes CSRF_HEADER_NAME.
CSRF_COOKIE_NAME=gl_csrf
CSRF_HEADER_NAME=X-CSRF-Token

# Temporary SPA bridge (Origin allowlist). Set AUTH_BOOTSTRAP_ENABLED=false to disable.
AUTH_BOOTSTRAP_ENABLED=true

# Optional: label current JWT signing key for future rotation logs (not yet used for verification).
# JWT_ACTIVE_KEY_ID=v1

# Comma-separated browser origins (no wildcard). Empty is not valid — default applied in code if unset.
CORS_ALLOWED_ORIGINS=http://localhost:4200
